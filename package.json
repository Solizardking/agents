{
  "name": "cheshire-terminal-agents",
  "version": "1.48.2",
  "description": "♾️  Cheshire Terminal Agents — 137 dual-chain agent definitions (Solana SVM + Robinhood Chain EVM), 53 characters, 31 deployable skills, on-chain identity forge, Metaplex Core minting, LayerZero zk-omni, and a full REST + MCP catalog API. One-shot npm install.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "Cheshire Terminal <operators@cheshireterminal.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Solizardking/agents.git"
  },
  "homepage": "https://cheshireterminal.ai/agents",
  "bugs": {
    "url": "https://github.com/Solizardking/agents/issues"
  },
  "keywords": [
    "cheshire-terminal",
    "cheshire-terminal-agents",
    "ai-agents",
    "defi",
    "solana",
    "robinhood-chain",
    "metaplex",
    "clawd",
    "mcp",
    "layerzero",
    "zk-omni",
    "erc-8004",
    "agent-catalog",
    "autonomous-agents",
    "web3",
    "blockchain"
  ],
  "bin": {
    "cheshire-terminal-agents": "./bin/ct-agents.cjs",
    "ct-agents": "./bin/ct-agents.cjs"
  },
  "exports": {
    ".": "./bin/ct-agents.cjs",
    "./catalog": "./robinhood-src/agentCatalog.js",
    "./agents/*": "./agents/*.json",
    "./schema/*": "./schema/*.json",
    "./skills": "./skills/suite-index.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node build-catalog.cjs && node scripts/validate-catalog.cjs && echo '✓ catalog built'",
    "validate": "node scripts/validate-catalog.cjs",
    "test": "node scripts/validate-catalog.cjs",
    "catalog": "node -e \"import('./agents-catalog.json').then(c => { const s=c.stats||c; console.log(JSON.stringify({agents:s.totalAgents,oneShots:s.totalOneShots,featured:s.totalFeatured,templates:s.totalTemplates,categories:Object.keys(s.byCategory||{}).length},null,2)) })\"",
    "start": "node bin/ct-agents.cjs serve",
    "prepublishOnly": "node build-catalog.cjs && node scripts/validate-catalog.cjs"
  },
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "bin/",
    "agents/",
    "characters/",
    "docs/",
    "examples/",
    "locales/",
    "minted/",
    "packages/",
    "public/.well-known/",
    "public/api/agents/",
    "public/assets/",
    "public/humans.txt",
    "robinhood-schema/",
    "robinhood-src/",
    "schema/",
    "scripts/",
    "skills/",
    "src/",
    "agents-catalog.json",
    "build-catalog.cjs",
    "README.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "viem": "^2.38.0"
  },
  "optionalDependencies": {
    "cheshire-terminal-agents": "^1.48.1"
  }
}