{
  "name": "cheshire-terminal-agents",
  "version": "1.48.3",
  "description": "♾️  Clawd Agents — dual-chain agent catalog + design TUI. Fork any agent as a template, customize against clawdAgentSchema.v1, validate, and ship. 137 catalog agents, scaffolds, characters, skills, Metaplex/Robinhood forge surfaces. npx cheshire-terminal-agents design",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "Cheshire Terminal <operators@cheshireterminal.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Solizardking/agents.git"
  },
  "homepage": "https://cheshireterminal.ai/agents",
  "bugs": {
    "url": "https://github.com/Solizardking/agents/issues"
  },
  "keywords": [
    "cheshire-terminal",
    "cheshire-terminal-agents",
    "ai-agents",
    "defi",
    "solana",
    "robinhood-chain",
    "metaplex",
    "clawd",
    "mcp",
    "layerzero",
    "zk-omni",
    "erc-8004",
    "agent-catalog",
    "autonomous-agents",
    "web3",
    "blockchain"
  ],
  "bin": {
    "cheshire-terminal-agents": "./bin/ct-agents.js",
    "ct-agents": "./bin/ct-agents.js"
  },
  "exports": {
    ".": "./bin/ct-agents.js",
    "./catalog": "./robinhood-src/agentCatalog.js",
    "./design": "./robinhood-src/designTui.js",
    "./agents/*": "./agents/*.json",
    "./templates/*": "./templates/*",
    "./schema/*": "./schema/*.json",
    "./skills": "./skills/suite-index.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node build-catalog.cjs && node scripts/validate-catalog.cjs && echo '✓ catalog built'",
    "validate": "node scripts/validate-catalog.cjs",
    "test": "node scripts/validate-catalog.cjs && node scripts/smoke-readme-npm.cjs && node bin/ct-agents.js design --list --json > /dev/null",
    "smoke:readme": "node scripts/smoke-readme-npm.cjs",
    "catalog": "node -e \"import('./agents-catalog.json').then(c => { const s=c.stats||c; console.log(JSON.stringify({agents:s.totalAgents,oneShots:s.totalOneShots,featured:s.totalFeatured,templates:s.totalTemplates,categories:Object.keys(s.byCategory||{}).length},null,2)) })\"",
    "start": "node bin/ct-agents.js design",
    "design": "node bin/ct-agents.js design",
    "forge": "node bin/ct-agents.js forge",
    "serve": "node bin/ct-agents.js serve",
    "prepublishOnly": "node build-catalog.cjs && node scripts/validate-catalog.cjs"
  },
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "bin/",
    "agents/",
    "characters/",
    "docs/",
    "examples/",
    "locales/",
    "minted/",
    "templates/",
    "public/.well-known/acp.json",
    "public/.well-known/ai-plugin.json",
    "public/api/agents/acp-registry.json",
    "public/api/agents/agents-catalog.json",
    "public/api/agents/index.json",
    "public/api/agents/catalog/index.json",
    "public/api/agents/registry/index.json",
    "public/api/agents/templates/",
    "public/assets/",
    "public/humans.txt",
    "robinhood-schema/",
    "robinhood-src/",
    "schema/",
    "scripts/",
    "skills/",
    "agents-catalog.json",
    "build-catalog.cjs",
    "README.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "viem": "^2.38.0"
  },
  "optionalDependencies": {
    "cheshire-terminal-agents": "^1.48.3"
  }
}
